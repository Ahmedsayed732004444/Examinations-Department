<file path="app/Services/UserDashboardService.php">
<?php

namespace App\Services;

use App\Models\User;
use Illuminate\Support\Facades\DB;

class UserDashboardService
{
    /**
     * Build all data needed for the user dashboard in an optimised way.
     *
     * @return array<string, mixed>
     */
    public function getData(User $user): array
    {
        // Active assessments ordered by domain (category) then title — single query
        $assessments = \App\Models\Assessment::where('is_active', true)
            ->withCount('questions')
            ->orderBy('category')
            ->orderBy('title_ar')
            ->get();

        // Completed sessions with assessment + result (eager-loaded)
        $completedSessions = $user->examSessions()
            ->where('status', 'completed')
            ->with(['assessment', 'result'])
            ->orderByDesc('completed_at')
            ->get();

        /*
         * Build progress map in a SINGLE query using a DB JOIN + GROUP BY,
         * replacing the previous approach that loaded all sessions in PHP.
         *
         * Result shape: { assessment_id => { completed: N, total: N } }
         */
        $progressRows = DB::table('exam_sessions')
            ->where('user_id', $user->id)
            ->select([
                'assessment_id',
                DB::raw('COUNT(*) as total'),
                DB::raw("SUM(CASE WHEN status = 'completed' THEN 1 ELSE 0 END) as completed"),
            ])
            ->groupBy('assessment_id')
            ->get();

        $progressMap = [];
        foreach ($progressRows as $row) {
            $progressMap[$row->assessment_id] = [
                'completed' => (int) $row->completed,
                'total'     => (int) $row->total,
            ];
        }

        return compact('assessments', 'completedSessions', 'progressMap');
    }
}
